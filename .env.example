# AI Business Analyst — environment variables

# Required — Anthropic Claude API key
ANTHROPIC_API_KEY=your-key-here

# Optional — Google PageSpeed API key (raises free quota from 25 → 25,000 req/day)
PAGESPEED_API_KEY=

# Optional — restrict CORS origin in production
# ALLOWED_ORIGIN=https://analyst.example.com

# Optional — Make.com webhook for lead capture (email form submissions)
# MAKE_WEBHOOK_URL=

PORT=3000
